    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "classnames": "2.5.1",
    "clipboard": "2.0.11",
    "connected-react-router": "6.9.3",
    "dnd-core": "^16.0.1",
    "element-class": "0.2.2",
