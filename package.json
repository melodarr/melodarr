    "@fortawesome/free-solid-svg-icons": "6.7.1",
    "@fortawesome/react-fontawesome": "0.2.2",
    "@juggle/resize-observer": "3.4.0",
    "@microsoft/signalr": "8.0.17",
    "@popperjs/core": "^2.11.8",
    "@sentry/browser": "7.119.1",
