FROM mcr.microsoft.com/dotnet/sdk:8.0

# Install Node.js (v20) and Yarn to match frontend requirements
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get update && apt-get install -y nodejs \
    && npm install -g yarn \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /source

# Wait indefinitely so we can `docker exec` commands into it transparently
CMD ["sleep", "infinity"]
